---
import Layout from "@/layouts/Layout.astro";
import siteData from "@/data/site.json";
import locationsData from "@/data/locations.json";
import servicesData from "@/data/services.json";

import Scene1Hero from "@/components/home/Scene1Hero";
import Scene3Services from "@/components/home/Scene3Services";
import AboutCompact from "@/components/home/AboutCompact.astro";
import LocationsCompact from "@/components/home/LocationsCompact.astro";
import Scene5Review from "@/components/home/Scene5Quote";

const reviews = [
  {
    text: "I've been seeing Kariny for over five years, and she is truly the best stylist. Her talent, professionalism, and attention to detail always exceed my expectations. I wouldn't trust anyone else with my hair.",
    author: "Jhoanny S.",
  },
  {
    text: "Pheobe is amazing. My hair was destroyed by a stylist in the past so I was very hesitant to ever come to a salon again. She has been babying and nourishing my hair back to health.",
    author: "Maria K.",
  },
  {
    text: "Karissa did a great job on my haircut! She is very sweet, patient, and really listens to what I wanted. She understood my needs and delivered exactly what I was hoping for.",
    author: "Anvesh K.",
  },
  {
    text: "Serena gave me one of the best men's haircut I've had. She listened carefully, understood exactly what I wanted, and delivered a clean, precise fade with sharp lines and perfect blending.",
    author: "Alexis W.",
  },
];
const review = reviews[Math.floor(Math.random() * reviews.length)];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  name: siteData.name,
  description:
    "Award-winning upscale hair salons in Tampa Bay. Balayage, precision cuts, color, extensions and treatments across 5 locations.",
  url: "https://jjosephsalon.com",
  telephone: siteData.phone,
  email: siteData.email,
  image: "https://jjosephsalon.com/images/og-image.jpg",
  priceRange: "$$",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "5.0",
    reviewCount: "789",
    bestRating: "5",
  },
  areaServed: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: 28.2197,
      longitude: -82.4663,
    },
    geoRadius: "30 mi",
  },
  sameAs: [
    siteData.social.instagram,
    siteData.social.tiktok,
    siteData.social.facebook,
  ],
  department: locationsData.map((loc: any) => ({
    "@type": "HairSalon",
    name: `J. Joseph Salon — ${loc.name}`,
    address: {
      "@type": "PostalAddress",
      streetAddress: loc.address,
      addressLocality: loc.city,
      addressRegion: loc.state,
      postalCode: loc.zip,
      addressCountry: "US",
    },
    telephone: loc.phone,
  })),
};
---

<Layout
  title="J. Joseph Salon | Best Hair Salon in Tampa Bay, FL"
  description="Award-winning upscale hair salons in Tampa Bay. Balayage, precision cuts, color, extensions & treatments. 5 locations. Book your appointment today."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </Fragment>

  <main>
    <Scene1Hero client:load />
    <Scene3Services client:visible services={servicesData.homepage_services} />
    <AboutCompact />
    <LocationsCompact />
    <Scene5Review client:visible review={review} />
  </main>
</Layout>
