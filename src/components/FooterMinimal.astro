---
import siteData from "@/data/site.json";
import locationsData from "@/data/locations.json";
---

<footer class="footer-closing bg-[var(--color-cream)]">
  <!-- Top section: CTA -->
  <div class="footer-cta px-6 md:px-12 pt-[60px] md:pt-[80px] pb-12 md:pb-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="font-heading text-[clamp(2.5rem,5vw,4.5rem)] font-bold leading-[0.92] tracking-[-0.03em] text-[var(--color-black)]">
        It's You<br />
        <span class="font-body italic text-[var(--color-gold)]">Time.</span>
      </h2>
      <a
        href="#book-now"
        class="group mt-8 inline-flex items-center gap-1.5 border-b border-[var(--color-gold)] pb-1 text-[0.85rem] text-[var(--color-black)] transition-colors duration-200 hover:text-[var(--color-gold)]"
      >
        <span>Request Appointment</span>
        <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
      </a>
    </div>
  </div>

  <!-- Middle section: contact + locations grid -->
  <div class="border-t border-[var(--color-black)]/[0.08] px-6 md:px-12 py-10 md:py-12">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 sm:grid-cols-[1.4fr_1fr_0.8fr] sm:gap-6">
      <!-- Column 1: Contact -->
      <div class="flex flex-col gap-2">
        <a
          href={`tel:${siteData.phone.replace(/[^0-9]/g, "")}`}
          class="font-heading text-[1.1rem] font-medium text-[var(--color-black)] transition-colors duration-200 hover:text-[var(--color-gold)]"
        >
          {siteData.phone}
        </a>
        <a
          href={`mailto:${siteData.email}`}
          class="text-[0.85rem] text-[var(--color-black)]/50 transition-colors duration-200 hover:text-[var(--color-black)]"
        >
          {siteData.email}
        </a>
      </div>

      <!-- Column 2: Locations -->
      <nav class="flex flex-col gap-1.5" aria-label="Salon locations">
        {locationsData.map((loc) => (
          <a
            href={`/locations#${loc.id}`}
            class="text-[0.82rem] text-[var(--color-black)]/[0.45] transition-colors duration-200 hover:text-[var(--color-black)]"
          >
            {loc.name}
          </a>
        ))}
      </nav>

      <!-- Column 3: Social -->
      <nav class="flex flex-col gap-1.5" aria-label="Social media">
        <a
          href={siteData.social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.82rem] text-[var(--color-black)]/[0.45] transition-colors duration-200 hover:text-[var(--color-black)]"
        >
          Instagram
        </a>
        <a
          href={siteData.social.tiktok}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.82rem] text-[var(--color-black)]/[0.45] transition-colors duration-200 hover:text-[var(--color-black)]"
        >
          TikTok
        </a>
        <a
          href={siteData.social.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[0.82rem] text-[var(--color-black)]/[0.45] transition-colors duration-200 hover:text-[var(--color-black)]"
        >
          Facebook
        </a>
      </nav>
    </div>
  </div>

  <!-- Bottom section: Legal -->
  <div class="border-t border-[var(--color-black)]/[0.06] px-6 md:px-12 py-5 md:py-6 pb-[32px] md:pb-[48px]">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <span class="text-[0.65rem] text-[var(--color-black)]/[0.25]">
        &copy; 2026 {siteData.name}
      </span>
      <div class="flex items-center gap-2 text-[0.65rem] text-[var(--color-black)]/[0.25]">
        <a href="/privacy-policy" class="transition-colors duration-200 hover:text-[var(--color-black)]/50">Privacy</a>
        <span>&middot;</span>
        <a href="/cookies-policy" class="transition-colors duration-200 hover:text-[var(--color-black)]/50">Cookies</a>
        <span>&middot;</span>
        <a href="/policies" class="transition-colors duration-200 hover:text-[var(--color-black)]/50">Policies</a>
        <span>&middot;</span>
        <a
          href={siteData.careers_url}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors duration-200 hover:text-[var(--color-black)]/50"
        >
          Careers
        </a>
      </div>
    </div>
  </div>
</footer>
