---
import site from "@data/site.json";
---

<footer class="border-t border-white/[0.04] px-6 md:px-8 py-6 md:py-2">
  <div class="flex flex-col md:flex-row items-center justify-between gap-3 text-[0.65rem] tracking-wider text-white/20">
    <!-- Copyright -->
    <span>&copy; {new Date().getFullYear()} {site.name}</span>

    <!-- Social links -->
    <div class="flex items-center gap-4">
      <a
        href={site.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white/50 transition-colors duration-200"
      >
        Instagram
      </a>
      <a
        href={site.social.tiktok}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white/50 transition-colors duration-200"
      >
        TikTok
      </a>
      <a
        href={site.social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-white/50 transition-colors duration-200"
      >
        Facebook
      </a>
    </div>

    <!-- Legal links -->
    <div class="flex items-center gap-2">
      <a href="/privacy-policy" class="hover:text-white/50 transition-colors duration-200">
        Privacy
      </a>
      <span class="text-white/10">&middot;</span>
      <a href="/cookies-policy" class="hover:text-white/50 transition-colors duration-200">
        Cookies
      </a>
    </div>
  </div>
</footer>
