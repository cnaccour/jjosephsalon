<section class="bg-cream px-6 py-24 md:px-12 md:py-32">
  <div class="mx-auto grid max-w-6xl grid-cols-1 items-end gap-12 md:grid-cols-[3fr_1fr] md:gap-16">
    <!-- Big headline -->
    <div>
      <h2
        class="font-heading text-[clamp(3.5rem,8vw,8rem)] font-bold leading-[0.88] tracking-[-0.04em] text-black"
      >
        It's You<br />
        <span class="font-body font-medium italic text-gold">Time.</span>
      </h2>
    </div>

    <!-- CTA side -->
    <div class="flex flex-col gap-6 pb-2">
      <p class="text-[0.85rem] leading-relaxed text-black/45">
        Schedule at your nearest J.&nbsp;Joseph&nbsp;Salon. Five locations across
        Tampa Bay, open seven days.
      </p>
      <a
        href="#book-now"
        class="group relative inline-flex items-center gap-3 overflow-hidden bg-black px-8 py-5 text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-cream transition-colors"
      >
        <span
          class="absolute inset-0 origin-left scale-x-0 bg-gold transition-transform duration-400 ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-x-100"
        ></span>
        <span class="relative z-10 transition-colors group-hover:text-black">
          Request Appointment
        </span>
        <span
          class="relative z-10 transition-all group-hover:translate-x-1 group-hover:text-black"
        >
          &rarr;
        </span>
      </a>
    </div>
  </div>
</section>
