---
import locations from "../../data/locations.json";
---

<div
  class="locations-strip"
  style="background: var(--color-surface); padding: 48px 40px;"
>
  <div class="locations-inner">
    <span class="locations-heading">
      5 locations across Tampa Bay
    </span>

    <span class="locations-list">
      {locations.map((loc, i) => (
        <>
          <a
            href={`/locations#${loc.id}`}
            class="locations-link"
          >
            {loc.name}
          </a>
          {i < locations.length - 1 && (
            <span class="locations-dot">&middot;</span>
          )}
        </>
      ))}
    </span>

    <a
      href="/locations"
      class="locations-view-all"
    >
      View all &rarr;
    </a>
  </div>
</div>

<style>
  .locations-strip {
    display: block;
  }

  .locations-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px 16px;
  }

  .locations-heading {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--color-cream);
    opacity: 0.5;
  }

  .locations-list {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px 8px;
  }

  .locations-link {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-cream);
    opacity: 0.4;
    text-decoration: none;
    transition: color 0.2s, opacity 0.2s;
  }

  .locations-link:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .locations-dot {
    font-size: 0.82rem;
    color: var(--color-cream);
    opacity: 0.25;
  }

  .locations-view-all {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-gold);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 0.2s;
  }

  .locations-view-all:hover {
    opacity: 0.75;
  }

  @media (max-width: 767px) {
    .locations-strip {
      padding: 32px 24px !important;
    }
  }
</style>
